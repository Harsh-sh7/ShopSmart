    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  }
}